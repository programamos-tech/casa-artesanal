# Copia este archivo a .env.local y completa los valores.
# Supabase → Settings → API: https://supabase.com/dashboard/project/cpbuodliotqjdqgnaqhk/settings/api
# Project ref: cpbuodliotqjdqgnaqhk

# --- Obligatorias (app + API routes con service role) ---
NEXT_PUBLIC_SUPABASE_URL=https://cpbuodliotqjdqgnaqhk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Opcionales: URLs públicas de la app ---
# Base absoluta (ej. https://tudominio.com). Si falta, las rutas API usan el origin del request.
# NEXT_PUBLIC_APP_URL=

# Dominio del catálogo /tienda: si coincide con el Host de la petición, / se reescribe a /tienda (middleware).
# Ejemplo: tienda.midominio.com
# NEXT_PUBLIC_CATALOG_HOST=

# URL canónica del sitio tienda (metadata / enlaces). Por defecto en código: https://casa-artesanal.com
# NEXT_PUBLIC_CATALOG_SITE_URL=

# --- Opcionales: integración API “andres” (/api/andres/*) ---
# Mismo valor en el header x-andres-api-key en las peticiones. Si no existe, las rutas responden 401.
# ANDRES_API_KEY=

# --- Solo scripts (no Next.js) ---
# scripts/seed-fake-clients.mjs — UUID de tienda por defecto si no pasas argumentos.
# SEED_STORE_ID=
